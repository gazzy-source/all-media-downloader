# =============================================================================
# All-Media Downloader Bot — environment template
# Copy to .env and fill in values. NEVER commit .env to git.
# =============================================================================

# Required — from @BotFather
BOT_TOKEN=

# Optional: comma-separated Telegram user IDs (bypass rate limits)
ADMIN_IDS=

# Concurrency & limits
MAX_CONCURRENT_DOWNLOADS=3
MAX_FILE_SIZE_MB=49
RATE_LIMIT_PER_HOUR=30

# Paths (relative to project root or absolute)
DOWNLOAD_DIR=downloads
TEMP_DIR=temp

# Optional: Netscape cookies for age-restricted / private public-ish content
# COOKIES_FILE=cookies.txt

# Optional: proxy (http://host:port or socks5://user:pass@host:port)
# PROXY=

# Optional: folder containing ffmpeg / ffmpeg.exe (auto-detected on many systems)
# FFMPEG_LOCATION=

# Optional profile overrides via Bot API (leave empty to keep @BotFather settings)
# BOT_NAME=All-Media Downloader Bot
# BOT_DESCRIPTION=Download videos, audio, and images from any platform instantly. Built by Gazzy Labs.
# BOT_SHORT_DESCRIPTION=Download videos, audio & images from any platform. Gazzy Labs.
